{
  "manifest_version": 3,
  "name": "Unbot",
  "version": "1.0.0",
  "description": "右键优化 AI 文本，让回复更像真人聊天",
  "permissions": ["contextMenus", "activeTab", "clipboardWrite", "storage", "scripting"],
  "host_permissions": ["https://unbot.limw.top/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unbot"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
